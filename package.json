{
  "name": "fabricly-website",
  "version": "1.0.0",
  "private": true,
  "description": "Fabricly — Custom apparel manufacturing website (HTML, Tailwind, Vanilla JS)",
  "scripts": {
    "dev:css": "tailwindcss -i ./src/css/input.css -o ./dist/css/output.css --watch",
    "build:css": "tailwindcss -i ./src/css/input.css -o ./dist/css/output.css --minify",
    "dev:serve": "npx --yes serve -l 5173 .",
    "dev": "npm-run-all --parallel dev:css dev:serve",
    "build": "tailwindcss -i ./src/css/input.css -o ./dist/css/output.css --minify"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.13",
    "npm-run-all": "^4.1.5"
  }
}
